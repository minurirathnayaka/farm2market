rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isOrderParticipant(order) {
      return isAuthenticated() && (
        order.buyerId == request.auth.uid ||
        order.farmerId == request.auth.uid ||
        order.transporterId == request.auth.uid
      );
    }

    function isThreadParticipant(thread) {
      return isAuthenticated() &&
        thread.participantIds is list &&
        thread.participantIds.hasAny([request.auth.uid]);
    }

    function isLegacyTransport(data) {
      return !("orderId" in data) || data.orderId == null;
    }

    match /users/{uid} {
      allow create: if isSelf(uid);
      allow read: if isAuthenticated();
      allow update, delete: if isSelf(uid);
    }

    match /stocks/{stockId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
        request.resource.data.farmerId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        resource.data.farmerId == request.auth.uid;
    }

    match /transport_requests/{requestId} {
      allow read: if isAuthenticated();

      // Legacy direct writes (non-order flow).
      allow create: if isAuthenticated() &&
        request.resource.data.farmerId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        isLegacyTransport(resource.data);
    }

    match /orders/{orderId} {
      allow read: if isOrderParticipant(resource.data);
      allow create, update, delete: if false;
    }

    match /threads/{threadId} {
      allow read: if isThreadParticipant(resource.data);
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isThreadParticipant(
          get(/databases/$(database)/documents/threads/$(threadId)).data
        );
        allow create, update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.recipientId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.recipientId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["readAt"]);

      allow create, delete: if false;
    }

    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
