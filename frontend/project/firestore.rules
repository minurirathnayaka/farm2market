rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isOrderParticipant(order) {
      return isAuthenticated() && (
        order.buyerId == request.auth.uid ||
        order.farmerId == request.auth.uid ||
        order.transporterId == request.auth.uid
      );
    }

    function isThreadParticipant(thread) {
      return isAuthenticated() &&
        thread.participantIds is list &&
        thread.participantIds.hasAny([request.auth.uid]);
    }

    function isLegacyTransport(data) {
      return !("orderId" in data) || data.orderId == null;
    }

    function hasPublicConfig() {
      return exists(/databases/$(database)/documents/app_config/public);
    }

    function publicConfig() {
      return get(/databases/$(database)/documents/app_config/public);
    }

    function maintenanceEnabled() {
      return hasPublicConfig() &&
        ("site" in publicConfig().data) &&
        publicConfig().data.site.maintenanceEnabled == true;
    }

    function signupEnabled() {
      return !hasPublicConfig() ||
        !("features" in publicConfig().data) ||
        publicConfig().data.features.signupEnabled != false;
    }

    function contactFormEnabled() {
      return !hasPublicConfig() ||
        !("features" in publicConfig().data) ||
        publicConfig().data.features.contactFormEnabled != false;
    }

    match /users/{uid} {
      allow create: if isSelf(uid) && signupEnabled() && !maintenanceEnabled();
      allow read: if isAuthenticated();
      allow update, delete: if isSelf(uid) && !maintenanceEnabled();
    }

    match /stocks/{stockId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
        !maintenanceEnabled() &&
        request.resource.data.farmerId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        !maintenanceEnabled() &&
        resource.data.farmerId == request.auth.uid;
    }

    match /transport_requests/{requestId} {
      allow read: if isAuthenticated();

      // Legacy direct writes (non-order flow).
      allow create: if isAuthenticated() &&
        !maintenanceEnabled() &&
        request.resource.data.farmerId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        !maintenanceEnabled() &&
        isLegacyTransport(resource.data);
    }

    match /orders/{orderId} {
      allow read: if isOrderParticipant(resource.data);
      allow create, update, delete: if false;
    }

    match /threads/{threadId} {
      allow read: if isThreadParticipant(resource.data);
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isThreadParticipant(
          get(/databases/$(database)/documents/threads/$(threadId)).data
        );
        allow create, update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.recipientId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.recipientId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["readAt"]);

      allow create, delete: if false;
    }

    match /contact_messages/{messageId} {
      allow create: if !maintenanceEnabled() && contactFormEnabled();
      allow read, update, delete: if false;
    }

    match /app_config/{docId} {
      allow read: if docId == "public";
      allow write: if false;
    }

    match /admin_audit_log/{auditId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
